# HydroScribe 环境变量配置模板
# 复制为 .env 并填入实际值: cp .env.example .env

# ── LLM 配置 ─────────────────────────────────────────────────────
# 方式一：阿里云百炼（推荐，低延迟）
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
LLM_PROVIDER=alibaba_bailian
LLM_MODEL=qwen-plus

# 方式二：OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1

# 方式三：Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-sonnet-4-20250514

# 方式四：本地模型 (Ollama/vLLM)
# LLM_PROVIDER=local
# LLM_MODEL=qwen2.5:14b
# LLM_BASE_URL=http://localhost:11434/v1

# ── 服务配置 ─────────────────────────────────────────────────────
HYDROSCRIBE_PORT=8000
LOG_LEVEL=info
GATE_MODE=auto

# ── OpenClaw 集成（可选）─────────────────────────────────────────
OPENCLAW_ENABLED=false
# OPENCLAW_LLM_API_KEY=
# OPENCLAW_LLM_BASE_URL=
# OPENCLAW_PORT=3000
# OPENCLAW_WEB_PORT=80
