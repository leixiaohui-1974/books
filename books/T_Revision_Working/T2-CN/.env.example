# T2-CN 图片生成 API 配置
# 复制本文件为 .env 并填入你的 API 密钥

# ═══ 方案一：Google Gemini（推荐，支持别名）═══
# NB_API_KEY   = AIzaSy你的密钥
# NB_API_BASE  = https://generativelanguage.googleapis.com/v1beta
# NB_MODEL     = nb2
#   别名表:
#     nb2 / nano-banana-2  → gemini-3.1-flash-image-preview  (2026-02, 最新推荐)
#     nb-pro / nano-banana-pro → gemini-3-pro-image-preview   (Pro架构)
#     nb / nano-banana      → gemini-2.5-flash-image          (原版)
#   也可直接写完整 model ID

# ═══ 方案二：kie.ai (Nano Banana 代理) ═══
# NB_API_KEY   = sk-你的密钥
# NB_API_BASE  = https://api.kie.ai
# NB_MODEL     = nano-banana-pro

# ═══ 方案三：OpenAI DALL-E ═══
# NB_API_KEY   = sk-你的密钥
# NB_API_BASE  = https://api.openai.com/v1
# NB_MODEL     = dall-e-3

# ═══ 通用配置 ═══
NB_RETRIES   = 3
NB_TIMEOUT   = 180
NB_POLL_MAX  = 300
NB_COOLDOWN  = 2
