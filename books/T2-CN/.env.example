# T2-CN 图片生成 API 配置
# 复制本文件为 .env 并填入你的 API 密钥

# ═══ 方案一：kie.ai (Nano Banana) ═══
# NB_API_KEY   = sk-你的密钥
# NB_API_BASE  = https://api.kie.ai
# NB_MODEL     = nano-banana-pro

# ═══ 方案二：Google Gemini ═══
# NB_API_KEY   = AIzaSy你的密钥
# NB_API_BASE  = https://generativelanguage.googleapis.com/v1beta
# NB_MODEL     = gemini-2.0-flash-exp

# ═══ 方案三：OpenAI DALL-E ═══
# NB_API_KEY   = sk-你的密钥
# NB_API_BASE  = https://api.openai.com/v1
# NB_MODEL     = dall-e-3

# ═══ 通用配置 ═══
NB_RETRIES   = 3
NB_TIMEOUT   = 180
NB_POLL_MAX  = 300
NB_COOLDOWN  = 2
