# T1-CN 图片生成配置
# 复制本文件为 .env 并填入 API 密钥

# API 提供商选择（三选一）：
# 方案一：kie.ai (Nano Banana)
NB_API_KEY  = sk-your-key-here
NB_API_BASE = https://api.kie.ai
NB_MODEL    = nano-banana-pro

# 方案二：Google Gemini
# NB_API_KEY  = AIzaSy...
# NB_API_BASE = https://generativelanguage.googleapis.com/v1beta
# NB_MODEL    = gemini-2.0-flash-exp

# 方案三：OpenAI 兼容接口
# NB_API_KEY  = sk-...
# NB_API_BASE = https://api.openai.com/v1
# NB_MODEL    = dall-e-3

# 通用配置
NB_STYLE    = chinese_engineering
NB_RETRIES  = 3
NB_TIMEOUT  = 180
NB_COOLDOWN = 2
